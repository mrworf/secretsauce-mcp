          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/ControlHealth"
                    },
                    "meta": {
                      "additionalProperties": false,
                      "properties": {
                        "api_version": {
                          "enum": [
                            "v2"
                          ],
                          "type": "string"
                        },
                        "request_id": {
                          "pattern": "^req_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
                          "type": "string"
                        }
                      },
                      "required": [
                        "request_id",
                        "api_version"
                      ],
                      "type": "object"
                    }
                  },
                  "required": [
                    "data",
                    "meta"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Control plane is not ready."
          }
        },
        "security": [],
        "summary": "Read sanitized control-plane readiness",
